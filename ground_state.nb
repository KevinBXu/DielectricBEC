Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"eq", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"hc", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "-", "v0"}], ")"}], "/", "v0"}], "]"}], "-", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"v0", "/", 
         RowBox[{"(", 
          RowBox[{"1", "-", "v0"}], ")"}]}], "]"}]}], ")"}]}], "+", 
    RowBox[{"2", " ", "hbar", " ", "gd", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"2", "v0"}], "-", "1"}], ")"}]}]}], "==", 
   RowBox[{"2", "h0"}]}]}]], "Input",
